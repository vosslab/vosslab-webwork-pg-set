#==========================================================
# HELPER FUNCTIONS
#==========================================================

sub escape_attr {
  my ($text) = @_;
  $text =~ s/&/&amp;/g;
  $text =~ s/"/&quot;/g;
  $text =~ s/</&lt;/g;
  $text =~ s/>/&gt;/g;
  return $text;
}

# count heavy atoms in SMILES for canvas sizing
sub count_heavy_atoms {
  my ($smiles) = @_;
  return 0 if $smiles eq '';
  my $count = 0;
  my $in_bracket = 0;
  for my $ch (split //, $smiles) {
    if ($ch eq '[') { $in_bracket = 1; $count++; }
    elsif ($ch eq ']') { $in_bracket = 0; }
    elsif (!$in_bracket && $ch ge 'A' && $ch le 'Z') { $count++; }
  }
  return $count;
}

# canvas width scales with sqrt(atom count)
sub canvas_width {
  my ($smiles) = @_;
  my $n = count_heavy_atoms($smiles);
  my $w = int(80 * sqrt($n));
  $w = 150 if $w < 150;
  $w = 380 if $w > 380;
  return $w;
}

