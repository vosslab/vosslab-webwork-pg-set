#==========================================================
# SELECT RANDOM QUESTION
#==========================================================

my $local_random = PGrandom->new();
$local_random->srand($problemSeed);

$question_idx = $local_random->random(0, scalar(@questions_data) - 1, 1);
$q = $questions_data[$question_idx];

$item_name = $q->{'item_name'};
@choices = @enzyme_choices;
$correct = $q->{'correct'};
$explanation = $q->{'explanation'};

#==========================================================
# BUILD VISUAL REACTION EQUATION
# Looks up molecule data from %molecules hash.
# Questions can override labels via label_left/label_right.
#==========================================================

my $mol_left_data  = $molecules{ $q->{'mol_left'} };
my $mol_right_data = $molecules{ $q->{'mol_right'} };

my $smiles_left  = $mol_left_data->{'smiles'};
my $smiles_right = $mol_right_data->{'smiles'};
my $extras_left  = $q->{'extras_left'};
my $extras_right = $q->{'extras_right'};

# use question label override if present, otherwise molecule default
my $label_left    = $q->{'label_left'}  || $mol_left_data->{'label'};
my $label_right   = $q->{'label_right'} || $mol_right_data->{'label'};
my $formula_left  = $mol_left_data->{'formula'};
my $formula_right = $mol_right_data->{'formula'};

# cofactor text style
my $cofactor_style = 'font-size: 1.3em; white-space: nowrap; padding: 0 0.2em;';

$structure_html = '<div style="display: flex; gap: 1em; align-items: center; justify-content: center; flex-wrap: wrap; margin: 0.8em 0 0.4em 0;">';

# --- left substrate structure ---
if ($smiles_left ne '') {
  my $w = canvas_width($smiles_left);
  my $smiles_attr = escape_attr($smiles_left);
  $structure_html .= '<div style="text-align: center;">'
    . '<canvas id="mol_left" width="' . $w . '" height="200" data-smiles="' . $smiles_attr . '"></canvas>'
    . '<div style="font-size: 0.9em; margin-top: 0.2em;">' . $label_left . '</div>';
  if ($formula_left ne '') {
    $structure_html .= '<div style="font-size: 0.8em; color: #555;">' . $formula_left . '</div>';
  }
  $structure_html .= '</div>';
}

# --- left extras (cofactors with substrate) ---
if ($extras_left ne '') {
  $structure_html .= '<div style="' . $cofactor_style . '">+ ' . $extras_left . '</div>';
}

# --- reaction arrow ---
$structure_html .= '<div style="font-size: 2em;">&rarr;</div>';

# --- right product structure ---
if ($smiles_right ne '') {
  my $w = canvas_width($smiles_right);
  my $smiles_attr = escape_attr($smiles_right);
  $structure_html .= '<div style="text-align: center;">'
    . '<canvas id="mol_right" width="' . $w . '" height="200" data-smiles="' . $smiles_attr . '"></canvas>'
    . '<div style="font-size: 0.9em; margin-top: 0.2em;">' . $label_right . '</div>';
  if ($formula_right ne '') {
    $structure_html .= '<div style="font-size: 0.8em; color: #555;">' . $formula_right . '</div>';
  }
  $structure_html .= '</div>';
}

# --- right extras (cofactors with product) ---
if ($extras_right ne '') {
  if ($smiles_right ne '') {
    # cofactors after the product structure
    $structure_html .= '<div style="' . $cofactor_style . '">+ ' . $extras_right . '</div>';
  } else {
    # no product structure, show cofactors as the product
    $structure_html .= '<div style="' . $cofactor_style . '">' . $extras_right . '</div>';
  }
}

$structure_html .= '</div>';

#==========================================================
# BUILD RADIO BUTTONS (choices stay in EC 1-6 order)
#==========================================================

$rb = RadioButtons(
  [@choices],
  $correct,
  labels        => 'ABC',
  displayLabels => 1,
  randomize     => 0,
  separator     => '<div style="margin-bottom: 0.7em;"></div>',
);

#==========================================================
# HEADER (RDKIT.JS)
#==========================================================

HEADER_TEXT(<<'END_HEADER');
<script src="https://unpkg.com/@rdkit/rdkit/dist/RDKit_minimal.js"></script>
<script>
let RDKitReady = null;
function getRDKit() {
	if (!RDKitReady) {
		RDKitReady = initRDKitModule();
	}
	return RDKitReady;
}
function initMoleculeCanvases() {
	getRDKit().then(function(RDKit) {
		const canvases = document.querySelectorAll('canvas[data-smiles]');
		canvases.forEach((canvas) => {
			const smiles = canvas.dataset.smiles;
			if (!smiles) {
				return;
			}
			const mol = RDKit.get_mol(smiles);
			const mdetails = {"explicitMethyl": true};
			if (canvas && mol) {
				mol.draw_to_canvas_with_highlights(canvas, JSON.stringify(mdetails));
				mol.delete();
			}
		});
	}).catch(error => {
		console.error('Error initializing RDKit:', error);
	});
}
if (document.readyState === 'loading') {
	document.addEventListener('DOMContentLoaded', initMoleculeCanvases);
} else {
	initMoleculeCanvases();
}
</script>
END_HEADER

#==========================================================
# PGML
#==========================================================

BEGIN_PGML

Which one of the following enzyme classes corresponds to the biochemical reaction [$item_name]*?

[$structure_html]*

[_]{$rb}

END_PGML

BEGIN_PGML_SOLUTION

The correct answer is: [$correct]*

[$explanation]*

END_PGML_SOLUTION

ENDDOCUMENT();
